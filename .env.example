PORT=6030

# OpenAI
OPENAI_API_KEY=

# Instruction Loading Methods (choose one):
# Method 1: Direct environment variable (highest priority)
OPENAI_INSTRUCTIONS="You are a helpful assistant that can answer questions and help with tasks."

# Method 2: Web service (medium priority) - uncomment to use
#OPENAI_URL_INSTRUCTIONS="https://your-api.com/instructions"

# Method 3: Local file (lowest priority) - uncomment to use
#OPENAI_FILE_INSTRUCTIONS="./instructions.txt"

# Optional OpenAI settings
#OPENAI_MODEL=gpt-realtime-2
#OPENAI_TEMPERATURE=0.8
#OPENAI_MAX_TOKENS=100
#OPENAI_VOICE=alloy
#OPENAI_LANGUAGE=it
#OPENAI_REASONING_EFFORT=low
#OPENAI_TRANSCRIPTION_MODEL=whisper-1
#OPENAI_TURN_DETECTION=server_vad
#OPENAI_TURN_DETECTION_EAGERNESS=medium

# Tools
# AMI_URL=

# AnchorDesk fallback ticket creation on call disconnect
# ANCHORDESK_API_URL=http://backend.materialticket.svc.cluster.local:8060
# ANCHORDESK_PAT=
# ANCHORDESK_FALLBACK_TICKETS=true
# ANCHORDESK_TIMEOUT_MS=8000

# Tool-wait audio and post-MCP voice watchdog
# AVR_TOOL_SFX=typing
# AVR_TOOL_SFX_MAX_MS=45000
# AVR_MCP_NUDGE_MS=1500
# AVR_MCP_NUDGE_MAX_ATTEMPTS=3

# Optional read-only Google Contacts caller enrichment (People API)
# GOOGLE_CONTACTS_CLIENT_ID=
# GOOGLE_CONTACTS_CLIENT_SECRET=
# GOOGLE_CONTACTS_REFRESH_TOKEN=
# GOOGLE_CONTACTS_DEFAULT_COUNTRY_CODE=1
# GOOGLE_CONTACTS_SYNC_INTERVAL_MS=3600000
